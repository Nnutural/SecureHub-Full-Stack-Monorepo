FRONTEND_PORT=5173
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# === Backend ===
DATABASE_URL=postgresql+asyncpg://securehub:securehub@postgres:5432/securehub
REDIS_URL=redis://redis:6379/0
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8000
DEBUG=false

# === LLM ===
LLM_PROVIDER=xfyun
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_MODEL=spark-v4
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# === Embedding ===
EMBEDDING_PROVIDER=bge_m3
EMBEDDING_DIM=1024

# === RAG ===
MIN_EVIDENCE=3
RETRIEVAL_TOP_K=8
RERANK_TOP_K=5

# === Router weights ===
ROUTER_W_CAP=0.35
ROUTER_W_CTX=0.25
ROUTER_W_TOOL=0.10
ROUTER_W_RISK=0.10
ROUTER_W_HIST=0.20
ROUTER_MIN_SCORE=0.4

# === Auth ===
JWT_SECRET=change-me
JWT_EXPIRE_HOURS=24

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8000
