# === LLM ===
XFYUN_APPID=__FILL_ME__
XFYUN_API_KEY=__FILL_ME__
XFYUN_API_SECRET=__FILL_ME__
XFYUN_SPARK_DOMAIN=4.0Ultra
XFYUN_TTS_APP_ID=__FILL_ME__
XFYUN_TTS_API_KEY=__FILL_ME__
XFYUN_TTS_API_SECRET=__FILL_ME__
DEEPSEEK_API_KEY=                       # 可空，空则不启用 fallback
QWEN_API_KEY=                           # 可空
LLM_PRIMARY=xfyun
LLM_FALLBACK_CHAIN=deepseek,qwen,mock   # 逗号分隔；mock 仅 dev

# === Embedding ===
EMBEDDING_PROVIDER=bge-m3               # bge-m3 | bge-large-zh | xfyun
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024                      # 与 chunks.embedding VECTOR(N) 一致；改值要重建 HNSW

# === Database ===
DATABASE_URL=postgresql+asyncpg://securehub:securehub@localhost:5432/securehub
REDIS_URL=redis://localhost:6379/0

# === Storage ===
STORAGE_PROVIDER=local                  # local | minio | s3 | oss | cos | r2
STORAGE_LOCAL_ROOT=./data/storage
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=securehub

# === MinerU ===
MINERU_MODE=manual                      # api | local | manual
MINERU_API_BASE=
MINERU_API_KEY=
MINERU_LOCAL_BIN=

# === Harness ===
HARNESS_MIN_EVIDENCE=3
HARNESS_TIMEOUT_SECONDS=60
HARNESS_DEFAULT_RETRY_MAX=1
HARNESS_MOCK_MODE=false                 # true 时 LLM/Retriever 走 fixtures

# === Crawling（成员 C 用；离线任务，非在线服务）===
CRAWL_RESPECT_ROBOTS=true
CRAWL_DEFAULT_DELAY_SECONDS=2
CRAWL_MAX_CONCURRENCY=2
CRAWL_USER_AGENT=SecureHub-Edu-Crawler/0.1 (compliance@securehub.local)

# === App ===
APP_NAME=SecureHub
API_V1_PREFIX=/api/v1
FRONTEND_ORIGINS=http://localhost:5173
DEBUG=true
