APP_NAME=securehub-backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
API_V1_PREFIX=/api/v1
FRONTEND_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
FRONTEND_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|\[::1\])(:\d+)?$
DEBUG=true

# --------------------------------------------------------------------------
# Database
# --------------------------------------------------------------------------
# Local dev / CI default: SQLite via aiosqlite — no Postgres container needed.
# Switch to PostgreSQL + pgvector for production / vector-index benchmarking.
DATABASE_URL=sqlite+aiosqlite:///./securehub_dev.db
# DATABASE_URL=postgresql+asyncpg://securehub:securehub@localhost:5432/securehub

# Redis is optional in dev — features that need it will degrade gracefully.
REDIS_URL=redis://localhost:6379/0
